PORT=3000
NODE_ENV=development

# Local DB variables (used in development/test)
DB_USER=postgres
DB_PASS=postgres
DB_NAME=url_shortener
DB_HOST=localhost
DB_PORT=5432

# Production DB variable (used in production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Daily top links report (notifications)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TOP_LINKS_LIMIT=10
TOP_LINKS_LOOKBACK_HOURS=24
